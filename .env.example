# Threads API 설정 (실제 값은 .env 파일에 입력, 절대 GitHub에 올리지 말 것)
THREADS_USER_ID=여기에_Threads_User_ID_입력
THREADS_ACCESS_TOKEN=여기에_장기_액세스_토큰_입력

# LinkedIn API 설정
# 발급 위치: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=여기에_Client_ID_입력
LINKEDIN_CLIENT_SECRET=여기에_Client_Secret_입력
# 아래 두 항목은 linkedin_auth.py 실행 후 자동 저장됨
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
